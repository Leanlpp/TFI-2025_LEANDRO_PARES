Algoritmo TRIANGULO
	Definir base Como Real
	Definir  altura Como Real
	Definir area Como Real
	//LA FORMULA QUE UTILIZO PARA CALCULAR EL AREA DEL TRIANGULO DADA SU BASE Y ALTURA ES
	//AREA = (BASE * ALTURA) /2
	
    Escribir "Ingrese la base en cm:"
    Leer base
	
    Escribir "Ingrese la altura en cm:"
    Leer altura
	
    area <- (base * altura) / 2 //UTILIZO LA FORMULA PARA CALCULAR EL AREA
	
    Escribir "El area es:", area," cm2";

FinAlgoritmo
